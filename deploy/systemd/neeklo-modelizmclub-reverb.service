[Unit]
Description=Neeklo Laravel Reverb WebSocket Server
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/modelizmclub-neeklo/backend
ExecStart=/usr/bin/php artisan reverb:start --host=127.0.0.1 --port=8082
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
