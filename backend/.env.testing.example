# Copy to .env.testing on the server (never use production DB for tests).
#   cp .env .env.testing
#   sed -i 's/^APP_ENV=.*/APP_ENV=testing/' .env.testing
#   sed -i 's/^DB_DATABASE=.*/DB_DATABASE=modelizmclub_test/' .env.testing
#
# Or run: bash deploy/scripts/setup-test-db.sh

APP_ENV=testing
APP_KEY=

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=modelizmclub_test
DB_USERNAME=modelizmclub
DB_PASSWORD=secret

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array

FEED_AUTO_PUBLISH=false
BILLING_PROVIDER=stub
