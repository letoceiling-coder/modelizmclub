APP_NAME=ModelizmClub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Moscow
APP_URL=http://localhost:8000

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=modelizmclub
DB_USERNAME=modelizmclub
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=modelizmclub
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=ws.modelizmclub.ru
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Selectel S3 (ru-3): https://docs.selectel.ru/en/api/object-storage/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ru-3
AWS_BUCKET=
AWS_ENDPOINT=https://s3.ru-3.storage.selcloud.ru
AWS_USE_PATH_STYLE_ENDPOINT=true

VKONTAKTE_CLIENT_ID=
VKONTAKTE_CLIENT_SECRET=
VKONTAKTE_REDIRECT_URI="${APP_URL}/api/v1/auth/oauth/vk/callback"

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI="${APP_URL}/api/v1/auth/oauth/yandex/callback"

# CDEK Delivery API v2 (https://apidoc.cdek.ru/)
CDEK_ENABLED=false
CDEK_TEST=true
CDEK_ACCOUNT=
CDEK_SECURE=
CDEK_TIMEOUT=10

# Yandex Delivery B2B API (отдельно от OAuth Yandex ID выше)
YANDEX_DELIVERY_ENABLED=false
YANDEX_DELIVERY_TOKEN=
YANDEX_DELIVERY_API_URL=https://b2b-authproxy.taxi.yandex.net
YANDEX_DELIVERY_TIMEOUT=15
YANDEX_DELIVERY_CALLBACK_URL=https://modelizmclub.ru/api/v1/webhooks/yandex/delivery-status?

# Dev: auto-approve posts on publish (production should be false)
FEED_AUTO_PUBLISH=false

# Frontend (CORS / payment return URLs)
FRONTEND_URL=https://modelizmclub.ru

# Billing: auto | vtb | yookassa | stub
BILLING_PROVIDER=stub
BILLING_RETURN_URL="${FRONTEND_URL}/subscription?payment=success"
BILLING_FAIL_URL="${FRONTEND_URL}/subscription?payment=failed"

# VTB Internet Acquiring (primary) — ИП Михайлов Д.М.
VTB_ACQUIRING_ENABLED=false
VTB_ACQUIRING_API_URL=https://vtb.rbsuat.com/payment/rest
VTB_ACQUIRING_USERNAME=
VTB_ACQUIRING_PASSWORD=
# Or token-based auth instead of username/password:
VTB_ACQUIRING_TOKEN=

# YooKassa (fallback) + Safe Deal (Безопасная сделка)
YOOKASSA_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_API_URL=https://api.yookassa.ru/v3
# 54-ФЗ fiscal receipt (чек). Required if the shop has онлайн-касса enabled.
# vat_code: 1=без НДС, 2=0%, 3=10%, 4=20%, 5=10/110, 6=20/120 (ИП/УСН обычно 1).
# tax_system_code: only if the shop has multiple tax systems (1=ОСН, 2=УСН доход, …).
YOOKASSA_RECEIPT_ENABLED=true
YOOKASSA_VAT_CODE=1
YOOKASSA_PAYMENT_SUBJECT=service
YOOKASSA_PAYMENT_MODE=full_payment
YOOKASSA_TAX_SYSTEM_CODE=
YOOKASSA_SAFE_DEAL_ENABLED=true
YOOKASSA_PLATFORM_FEE_PERCENT=5

# Media transcription (voice-message speech-to-text)
# Provider: "stub" (fixed placeholder text) or "yandex" (Yandex SpeechKit).
# Leave MEDIA_TRANSCRIPTION_STUB=true for the placeholder. To enable real STT:
#   MEDIA_TRANSCRIPTION_STUB=false and set MEDIA_TRANSCRIPTION_PROVIDER=yandex
#   plus the Yandex SpeechKit credentials below.
MEDIA_TRANSCRIPTION_STUB=true
# MEDIA_TRANSCRIPTION_PROVIDER=yandex
# Yandex SpeechKit (https://console.cloud.yandex.ru → SpeechKit → API key + folder id)
YANDEX_SPEECHKIT_API_KEY=
YANDEX_SPEECHKIT_FOLDER_ID=
YANDEX_SPEECHKIT_LANG=ru-RU
# ffmpeg is required to normalize/segment browser audio (webm/opus) for SpeechKit.
FFMPEG_BINARY=ffmpeg
MEDIA_TRANSCRIPTION_SEGMENT_SECONDS=25

VITE_APP_NAME="${APP_NAME}"
